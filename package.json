{
  "name": "@ai-inquisitor/cadmus",
  "version": "0.6.0",
  "description": "CTranslate2-based Whisper transcription with prebuilt napi-rs binaries.",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "cadmus.darwin-arm64.node",
    "cadmus.linux-x64-gnu.node",
    "LICENSE",
    "LICENSE-THIRD-PARTY",
    "README.md"
  ],
  "napi": {
    "binaryName": "cadmus",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:napi": "napi build --release --platform --no-js --dts napi-binding.d.ts --features napi",
    "build:ts": "tsc",
    "build": "npm run build:napi && npm run build:ts",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
